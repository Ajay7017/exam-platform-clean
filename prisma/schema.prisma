generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // Add this line
}

// ============================================
// AUTHENTICATION MODELS
// ============================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  phone         String?   @unique
  phoneVerified Boolean   @default(false)
  role          String    @default("student") // "student" | "admin"
  isBlocked     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  
  accounts    Account[]
  sessions    Session[]
  attempts    Attempt[]
  purchases   Purchase[]
  leaderboard LeaderboardEntry[]
  feedbacks   ExamFeedback[]
  errorReports ErrorReport[]
  
  @@index([email])
  @@index([phone])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// CONTENT MODELS
// ============================================
model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  
  topics        Topic[]
  exams         Exam[]
  subscriptions Subscription[]
  
  @@index([slug])
  @@index([isActive])
}

model Topic {
  id        String   @id @default(cuid())
  name      String
  slug      String
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  subTopics SubTopic[]
  questions Question[]
  
  @@unique([subjectId, name])
  @@index([subjectId, isActive])
}

// ✅ NEW: SubTopic model — 3rd level in content hierarchy
model SubTopic {
  id        String   @id @default(cuid())
  name      String
  slug      String
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions Question[]

  @@unique([topicId, name])
  @@index([topicId, isActive])
}

enum Difficulty {
  easy
  medium
  hard
}

model Question {
  id            String     @id @default(cuid())
  statement     String     @db.Text
  imageUrl      String?
  topicId       String
  topic         Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subTopicId    String?
  subTopic      SubTopic?  @relation(fields: [subTopicId], references: [id], onDelete: SetNull)
  marks         Int        @default(1)
  negativeMarks Float      @default(0.25)
  explanation   String?    @db.Text
  difficulty    Difficulty @default(medium)
  isActive      Boolean    @default(true)
  version       Int        @default(1)
  contentHash   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // ✅ NEW: NAT Question Fields
  type                String  @default("mcq") // "mcq" | "numerical" | "match"
  correctAnswerExact  Float?
  correctAnswerMin    Float?
  correctAnswerMax    Float?

  // ✅ NEW: Match Question Fields
  matchPairs          Json?   // { leftColumn: { header: string, items: string[] }, rightColumn: { header: string, items: string[] } }
  
  options       Option[]
  examQuestions ExamQuestion[]
  errorReports  ErrorReport[]
  
  @@index([topicId, isActive])
  @@index([subTopicId])
  @@index([difficulty])
  @@index([contentHash])    
}

model Option {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String   @db.Text
  imageUrl   String?
  isCorrect  Boolean  @default(false)
  optionKey  String   // "A", "B", "C", "D"
  sequence   Int
  createdAt  DateTime @default(now())
  
  @@index([questionId])
}

// ============================================
// EXAM MODELS
// ============================================
model Exam {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  description     String?    @db.Text
  thumbnail       String?
  subjectId       String?
  subject         Subject?   @relation(fields: [subjectId], references: [id])
  isMultiSubject  Boolean    @default(false)
  durationMin     Int
  totalMarks      Int
  passingMarks    Int?
  price           Int
  isPaid          Boolean    @default(true)
  isFree          Boolean    @default(false)
  isPublished     Boolean    @default(false)
  instructions    String?    @db.Text
  allowReview     Boolean    @default(true)
  randomizeOrder  Boolean    @default(true)
  difficulty      Difficulty @default(medium)
  rating          Float      @default(0)
  totalAttempts   Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  questions         ExamQuestion[]
  attempts          Attempt[]
  purchases         Purchase[]
  leaderboard       LeaderboardEntry[]
  subscriptionExams SubscriptionExam[]
  bundleExams       BundleExam[]

  feedbacks         ExamFeedback[]
  errorReports      ErrorReport[]

  tags  String[]  @default([])
  
  @@index([slug])
  @@index([isPublished])
  @@index([subjectId])
}

model ExamQuestion {
  id         String   @id @default(cuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  sequence   Int
  createdAt  DateTime @default(now())
  
  @@unique([examId, questionId])
  @@index([examId])
  @@index([questionId])
}

// ============================================
// SUBSCRIPTION & BUNDLE MODELS
// ============================================
model Subscription {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  subjectId    String?
  subject      Subject? @relation(fields: [subjectId], references: [id])
  durationDays Int
  price        Int
  discount     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  
  exams     SubscriptionExam[]
  purchases Purchase[]
}

model SubscriptionExam {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  examId         String
  exam           Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  @@unique([subscriptionId, examId])
}

model Bundle {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  price        Int
  discount     Int      @default(0)
  isActive     Boolean  @default(true)
  validityDays Int      @default(365)
  createdAt    DateTime @default(now())
  thumbnail       String?
  
  exams     BundleExam[]
  purchases Purchase[]
}

model BundleExam {
  id       String @id @default(cuid())
  bundleId String
  bundle   Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  examId   String
  exam     Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  @@unique([bundleId, examId])
}

// ============================================
// PURCHASE & PAYMENT MODELS
// ============================================
model Purchase {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  examId         String?
  exam           Exam?         @relation(fields: [examId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  bundleId       String?
  bundle         Bundle?       @relation(fields: [bundleId], references: [id])
  type           String        // "single_exam" | "subscription" | "bundle"
  price          Int
  status         String        @default("pending")
  validFrom      DateTime      @default(now())
  validUntil     DateTime?
  purchasedAt    DateTime      @default(now())
  refundedAt     DateTime?
  
  payment Payment?
  
  @@index([userId, status])
  @@index([examId, userId])
}

model Payment {
  id                 String    @id @default(cuid())
  purchaseId         String    @unique
  purchase           Purchase  @relation(fields: [purchaseId], references: [id])
  razorpayOrderId    String?   @unique
  razorpayPaymentId  String?   @unique
  razorpaySignature  String?
  amount             Int
  currency           String    @default("INR")
  status             String    @default("created")
  method             String?
  failureReason      String?
  createdAt          DateTime  @default(now())
  paidAt             DateTime?
  
  @@index([razorpayOrderId])
  @@index([status])
}

// ============================================
// ATTEMPT & LEADERBOARD MODELS
// ============================================
model Attempt {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  examId         String
  exam           Exam      @relation(fields: [examId], references: [id])
  
  startedAt      DateTime  @default(now())
  submittedAt    DateTime?
  expiresAt      DateTime
  timeSpentSec   Int       @default(0)
  
  totalQuestions Int
  
  answers        Json      @default("{}")
  timePerQuestion  Json  @default("{}")
  
  correctAnswers Int       @default(0)
  wrongAnswers   Int       @default(0)
  unattempted    Int       @default(0)
  score          Float?
  percentage     Float?
  rank           Int?
  percentile     Float?
  
  status         String    @default("in_progress")
  hasSubmitted   Boolean   @default(false)
  isOfficial     Boolean   @default(true)
  
  ipAddress      String?
  tabSwitchCount Int       @default(0)
  suspiciousFlags Json?    @default("[]")
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  leaderboardEntry LeaderboardEntry?
  
  @@index([userId, examId])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, examId, hasSubmitted, isOfficial])
  @@index([examId, status, isOfficial])
}

model LeaderboardEntry {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  attemptId   String   @unique
  attempt     Attempt  @relation(fields: [attemptId], references: [id])
  score       Float
  percentage  Float
  percentile  Float    @default(0)
  rank        Int
  timeTaken   Int
  submittedAt DateTime

  @@unique([examId, userId])
  @@index([examId, rank])
  @@index([userId])
}

// ============================================
// ADMIN MODELS
// ============================================
model ImportJob {
  id             String    @id @default(cuid())
  adminId        String
  fileName       String
  subjectId      String
  topicId        String
  totalQuestions Int
  successCount   Int       @default(0)
  failedCount    Int       @default(0)
  skippedCount   Int       @default(0)
  status         String    @default("queued")
  errors         Json?
  previewData    Json?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  
  @@index([status])
}

model EmailLog {
  id         String    @id @default(cuid())
  userId     String?
  email      String
  type       String
  subject    String
  status     String    @default("pending")
  provider   String    @default("sendgrid")
  providerId String?
  error      String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
  
  @@index([status])
  @@index([type])
}

// ============================================
// STUDY MATERIAL MODELS
// ============================================
model StudyMaterial {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  subject     String   // e.g., "Physics", "Chemistry", "Mathematics", "Biology"
  type        String   // e.g., "PDF", "Drive Folder", "Video"
  link        String   // The Google Drive or external URL
  thumbnailUrl String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subject])
  @@index([isPublished])
}

// ============================================
// FEEDBACK & ERROR REPORT MODELS
// ============================================

model ExamFeedback {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  attemptId     String

  // Student inputs
  difficultyRating  Int      // 1-5
  experienceRating  Int      // 1-5
  comments          String?  @db.Text

  // Admin response
  status        String   @default("pending") // "pending" | "acknowledged" | "fixed"
  adminReply    String?  @db.Text
  repliedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([examId])
  @@index([attemptId])
  @@index([status])
}

model ErrorReport {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  attemptId     String
  questionId    String
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Student inputs
  questionNumber  Int      // for display reference
  issueType       String   // "wrong_answer" | "wrong_question" | "typo" | "image_issue" | "other"
  description     String   @db.Text

  // Admin response
  status        String   @default("pending") // "pending" | "acknowledged" | "fixed"
  adminReply    String?  @db.Text
  repliedAt     DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([examId])
  @@index([attemptId])
  @@index([questionId])
  @@index([status])
}